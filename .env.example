# ================================================================
# Agrotec Frontend (Visor + FastAPI) - .env
# Generado: Sun May 17 01:52:36 PM CEST 2026
# ================================================================

COMPOSE_PROJECT_NAME=agrotec-fr

# --- PostgreSQL propio del visor (cache, capas, configuracion) ---
POSTGRES_DB=agrotecdb
POSTGRES_USER=agrotecuser
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_PORT=55433

GISDB_HOST=agrotec_db
GISDB_PORT=5432
GISDB_NAME=agrotecdb
GISDB_USER=agrotecuser
GISDB_PASSWORD=__CHANGE_ME__

# --- pgAdmin (deshabilitado: usar el global en https://desarrollowebsite.com/pgadmin/) ---
PGADMIN_DEFAULT_EMAIL=admin@agrotec.local
PGADMIN_DEFAULT_PASSWORD=__CHANGE_ME__

# --- FastAPI ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4
CORS_ORIGINS=https://desarrollowebsite.com,http://localhost:8089

# --- GeoNode backend (red interna agrotec-net) ---
GEONODE_BASE_URL=http://nginx4agrotec:80
GEONODE_PUBLIC_BASE_URL=https://agrotec.tudominio.com
GEONODE_PUBLIC_WMS_URL=https://agrotec.tudominio.com/geoserver/ows
GEONODE_PUBLIC_WFS_URL=https://agrotec.tudominio.com/geoserver/ows
GEONODE_INTERNAL_WFS_URL=http://geoserver4agrotec:8080/geoserver/ows
GEONODE_HOST_HEADER=agrotec.tudominio.com

# --- OAuth (rellenar tras desplegar GeoNode y crear app) ---
GEONODE_OAUTH_CLIENT_ID=
GEONODE_OAUTH_CLIENT_SECRET=
GEONODE_OAUTH_TOKEN_URL=https://desarrollowebsite.com/agrotec-geonode/o/token/
GEONODE_SERVICE_USERNAME=visor-admin
GEONODE_SERVICE_PASSWORD=

# --- Cache de capas ---
STATIC_LAYER_REFRESH_ZONAS=300
