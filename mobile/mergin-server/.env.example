# =============================================================================
# Mergin Maps server (community) - .env
# Generado: Sun May 17 04:45:45 PM CEST 2026
# =============================================================================

MERGIN_VERSION=2025.7.3

# DB
POSTGRES_DB=mergin
POSTGRES_USER=mergin
POSTGRES_PASSWORD=__CHANGE_ME__
DB_HOST=db
DB_PORT=5432
DB_USER=mergin
DB_PASSWORD=__CHANGE_ME__
DB_DATABASE=mergin

# Flask
FLASK_APP=application
FLASK_DEBUG=0
SECRET_KEY=__CHANGE_ME__

# URL publica (cuando este DNS arriba)
MERGIN_BASE_URL=https://mergin.desarrollowebsite.com
CONTACT_EMAIL=admin@desarrollowebsite.com

# Paths
LOCAL_PROJECTS=/data
TEMP_DIR=/data/tmp
MAINTENANCE_FILE=/data/MAINTENANCE

# Redis
REDIS_URL=redis://redis:6379/0

# Limites (200 MB por archivo, ajustar segun proyectos)
MAX_FILE_SIZE_BYTES=209715200

# SMTP deshabilitado por defecto
MAIL_SUPPRESS_SEND=True

# Admin inicial (lo creamos manual con CLI tras primer arranque)
ADMIN_USER=admin
ADMIN_EMAIL=admin@desarrollowebsite.com
ADMIN_PASSWORD=__CHANGE_ME__
